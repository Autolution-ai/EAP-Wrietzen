# Beispiel-Umgebungsvariablen fuer den Bewerbungs-Funnel.
# Diese Datei wird committet, .env.local NICHT.
# Kunde traegt hier spaeter sein Postfach / seinen Versandweg ein.

# Zieladresse fuer eingehende Bewerbungen
BEWERBUNG_EMPFAENGER="bewerbung@example.de"

# Optional: Resend API Key (https://resend.com) fuer echten Mailversand
# RESEND_API_KEY=""
